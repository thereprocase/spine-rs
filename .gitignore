# Build
core/target/
apps/desktop/dist/
apps/desktop/src-tauri/target/
node_modules/

# OS/IDEs
.vscode/
.DS_Store
Thumbs.db
.claude/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test Data
test-lib/
test-data/
temp_schema.sql
code-cache/

# Rust
**/*.rs.bk
# core/Cargo.lock is intentionally tracked (workspace binary — reproducible builds)
# apps/desktop/src-tauri/Cargo.lock is also tracked for the same reason
apps/desktop/src-tauri/*.db

# Alpha ring artefacts — MSIs are too big to commit; keep BUILDS.md + README.
artifacts/alpha/*.msi
# Regenerated by scripts/build-alpha.sh each run.
apps/desktop/src-tauri/tauri.alpha.json

# APK ring artefacts — 30MB+ debug APKs shouldn't be committed; keep BUILDS.md.
artifacts/apk/*.apk

benchmark_tool/target

# machine-local notes — never committed
.local/
